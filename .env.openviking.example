# OpenViking Memory Plugin Configuration
# =========================================
# Copy this file to .env and configure the values below

# OpenViking Server Endpoint
# ---------------------------
# URL of the OpenViking server. Use localhost for local installations,
# or the container name 'openviking' when using docker-compose.
# Default: http://127.0.0.1:1933
OPENVIKING_ENDPOINT=http://127.0.0.1:1933

# OpenViking API Key (Optional)
# -----------------------------
# API key for authenticated OpenViking servers. Leave blank for local
# development mode where authentication is not required.
# Default: (empty)
OPENVIKING_API_KEY=

# OpenViking Account (Tenant)
# ---------------------------
# Multi-tenant account identifier. Use 'default' for single-user setups.
# Default: default
OPENVIKING_ACCOUNT=default

# OpenViking User
# ---------------
# User identifier within the account. Use 'default' for single-user setups.
# Default: default
OPENVIKING_USER=default

# OpenViking Agent
# ----------------
# Agent identifier within the account. Useful in multi-agent scenarios
# where multiple agents share the same OpenViking instance.
# Default: hermes
OPENVIKING_AGENT=hermes

# Embedding Model Configuration
# -----------------------------
# Embedding model for semantic search and retrieval.
# Options: BAAI/bge-small-zh-v1.5, BAAI/bge-base-zh-v1.5, BAAI/bge-large-zh-v1.5
#          sentence-transformers/all-MiniLM-L6-v2 (English)
# Default: BAAI/bge-small-zh-v1.5
OPENVIKING_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# Embedding Model Device
# ----------------------
# Device for running the embedding model: cpu, cuda, mps (Apple Silicon)
# Default: cpu
OPENVIKING_EMBEDDING_DEVICE=cpu

# Vision Language Model (VLM) Configuration
# -----------------------------------------
# VLM for processing images and multimodal content.
# Options: Qwen/Qwen2-VL-2B-Instruct, Qwen/Qwen2-VL-7B-Instruct
# Default: Qwen/Qwen2-VL-2B-Instruct
OPENVIKING_VLM_MODEL=Qwen/Qwen2-VL-2B-Instruct

# VLM Device
# ----------
# Device for running the VLM: cpu, cuda, mps (Apple Silicon)
# Default: cpu
OPENVIKING_VLM_DEVICE=cpu
