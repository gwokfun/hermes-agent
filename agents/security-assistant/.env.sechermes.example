# ===========================================================================
# SecHermes Environment Configuration
# ===========================================================================
# Copy to .env.sechermes and fill in required values.
# Pass to Docker: docker run --env-file .env.sechermes ...
#
# Required variables are marked with [REQUIRED].
# Everything else has sensible defaults.
# ===========================================================================

# ===========================================================================
# [REQUIRED] LLM Provider — at least one is required
# ===========================================================================

# Anthropic (recommended for security analysis accuracy)
ANTHROPIC_API_KEY=

# Or use OpenRouter for multi-model access
# OPENROUTER_API_KEY=

# Default model (override in config.yaml or here)
# LLM_MODEL=anthropic/claude-sonnet-4-20250514

# ===========================================================================
# OpenViking Memory System
# ===========================================================================
# Defaults are pre-configured for Docker Compose networking.
# Override only if running OpenViking elsewhere.

OPENVIKING_ENDPOINT=http://openviking:1933
# OPENVIKING_API_KEY=              # Leave blank for local dev mode
OPENVIKING_ACCOUNT=default
OPENVIKING_USER=default
OPENVIKING_AGENT=sechermes

# Embedding model (Chinese security docs → use bge-zh)
OPENVIKING_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
OPENVIKING_EMBEDDING_DEVICE=cpu

# VLM for image/screenshot analysis (optional)
# OPENVIKING_VLM_MODEL=Qwen/Qwen2-VL-2B-Instruct
# OPENVIKING_VLM_DEVICE=cpu

# Max seconds to wait for OpenViking on startup (default: 30)
# OPENVIKING_WAIT_RETRIES=30

# ===========================================================================
# Security Tools
# ===========================================================================

# NVD API Key — increases rate limit from 5/30s to 50/30s
# Register: https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=

# Approval API — for sec-auto-fix skill
# APPROVAL_API_URL=https://your-approval-system/api/v1
# APPROVAL_API_TOKEN=

# ===========================================================================
# Web Search (for sec-intel skill)
# ===========================================================================
# At least one is recommended for security intelligence gathering.

# Parallel Web (default provider)
# PARALLEL_API_KEY=

# Firecrawl (alternative)
# FIRECRAWL_API_KEY=

# Exa (alternative)
# EXA_API_KEY=

# ===========================================================================
# Messaging Gateway (optional)
# ===========================================================================
# Enable if you want to interact with SecHermes via chat platforms.

# Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=

# Discord
# DISCORD_BOT_TOKEN=

# Slack
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# ===========================================================================
# Terminal
# ===========================================================================
TERMINAL_TIMEOUT=60

# ===========================================================================
# Security Docs Path (mounted volume)
# ===========================================================================
# Path inside the container where internal security docs are mounted.
# Mount: -v /path/to/your/docs:/opt/sec-docs:ro
SEC_DOCS_BASE_PATH=/opt/sec-docs
